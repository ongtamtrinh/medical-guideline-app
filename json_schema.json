{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "MedicalGuideline",
  "type": "object",
  "required": ["id", "title", "version", "sections"],

  "properties": {
    "id": { "type": "string", "example": "sep-001" },
    "title": { "type": "string" },
    "version": { "type": "string", "example": "3.2" },
    "icd10": { "type": "string", "example": "A41.9" },
    "status": { "type": "string", "enum": ["draft", "active", "archived"] },
    "priority": { "type": "string", "enum": ["routine", "urgent", "emergency"] },
    "department": { "type": "string" },
    "createdAt": { "type": "string", "format": "date" },
    "updatedAt": { "type": "string", "format": "date" },
    "authors": { "type": "array", "items": { "type": "string" } },
    "qrUrl": { "type": "string", "format": "uri" },

    "versions": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "version": { "type": "string" },
          "date": { "type": "string", "format": "date" },
          "note": { "type": "string" },
          "authorId": { "type": "string" }
        }
      }
    },

    "redFlags": {
      "type": "array",
      "description": "Dấu hiệu nguy hiểm — hiển thị nổi bật màu đỏ",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "text": { "type": "string" },
          "severity": { "type": "string", "enum": ["warning", "critical"] }
        }
      }
    },

    "contraindications": {
      "type": "array",
      "description": "Chống chỉ định tuyệt đối",
      "items": { "type": "string" }
    },

    "medications": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "doseFormula"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "genericName": { "type": "string" },
          "route": { "type": "string", "enum": ["IV", "PO", "IM", "SC", "Inhal"] },

          "doseFormula": {
            "type": "object",
            "description": "Logic tính liều động theo cân nặng / tuổi",
            "properties": {
              "type": {
                "type": "string",
                "enum": ["weight_based", "fixed", "bsa_based", "age_based"]
              },
              "perKg": { "type": "number", "description": "mcg/kg/phút hoặc mg/kg" },
              "unit": { "type": "string", "example": "mcg/kg/phút" },
              "minDose": { "type": "number" },
              "maxDose": { "type": "number" },
              "frequency": { "type": "string", "example": "mỗi 6 giờ" },
              "customFormula": {
                "type": "string",
                "description": "Công thức JS eval-safe: 'weight * 0.1' hoặc 'Math.min(weight * 50, 3000)'"
              }
            }
          },

          "dilution": {
            "type": "object",
            "description": "Hướng dẫn pha thuốc cho điều dưỡng",
            "properties": {
              "amount": { "type": "number", "description": "Lượng thuốc (mg)" },
              "volume": { "type": "number", "description": "Thể tích dung dịch pha (ml)" },
              "solvent": { "type": "string", "example": "NaCl 0.9%" },
              "concentration": { "type": "string", "example": "4mg/50ml" },
              "infusionRate": { "type": "string" },
              "infusionDuration": { "type": "string", "example": "30 phút" }
            }
          },

          "nursingNotes": {
            "type": "string",
            "description": "Chú ý đặc biệt dành cho điều dưỡng"
          },
          "monitoring": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Thông số cần theo dõi khi dùng thuốc"
          }
        }
      }
    },

    "diagnosticCriteria": {
      "type": "object",
      "properties": {
        "scoringSystems": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string", "example": "SOFA" },
              "threshold": { "type": "number" },
              "interpretation": { "type": "string" }
            }
          }
        },
        "labValues": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "unit": { "type": "string" },
              "criticalHigh": { "type": "number" },
              "criticalLow": { "type": "number" },
              "targetRange": {
                "type": "object",
                "properties": { "min": { "type": "number" }, "max": { "type": "number" } }
              }
            }
          }
        }
      }
    },

    "flowchart": {
      "type": "object",
      "description": "Sơ đồ xử trí dạng cây quyết định",
      "properties": {
        "nodes": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "type": { "type": "string", "enum": ["action", "decision", "start", "end"] },
              "label": { "type": "string" },
              "note": { "type": "string" },
              "timeTarget": { "type": "string", "example": "Trong 1 giờ" },
              "color": { "type": "string", "enum": ["default", "danger", "warning", "success"] }
            }
          }
        },
        "edges": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "from": { "type": "string" },
              "to": { "type": "string" },
              "label": { "type": "string", "example": "Có / Không" }
            }
          }
        }
      }
    },

    "sections": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title", "content"],
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "orderIndex": { "type": "integer" },
          "audienceFilter": {
            "type": "string",
            "enum": ["all", "doctor", "nurse"],
            "description": "Hiển thị theo vai trò người dùng"
          },
          "content": {
            "type": "string",
            "description": "Nội dung Markdown"
          },
          "embeddedComponents": {
            "type": "array",
            "description": "Components tương tác nhúng vào section",
            "items": {
              "type": "object",
              "properties": {
                "type": {
                  "type": "string",
                  "enum": ["dosage_calculator", "red_flag_box", "lab_reference_table", "flowchart"]
                },
                "props": { "type": "object" }
              }
            }
          }
        }
      }
    },

    "patientEducation": {
      "type": "object",
      "description": "Nội dung hướng dẫn bệnh nhân — ngôn ngữ đơn giản",
      "properties": {
        "summary": { "type": "string" },
        "whatToExpect": { "type": "array", "items": { "type": "string" } },
        "warningSignsToReport": { "type": "array", "items": { "type": "string" } },
        "doList": { "type": "array", "items": { "type": "string" } },
        "dontList": { "type": "array", "items": { "type": "string" } },
        "followUpDate": { "type": "string" }
      }
    }
  }
}
